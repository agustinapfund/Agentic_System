# Configuración de Agentic System
# Copia este archivo a .env y completa con tus valores

# ========================================
# OpenAI Configuration
# ========================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ========================================
# Semantic Kernel Configuration
# ========================================
SK_LOG_LEVEL=INFO
SK_PLANNING_MODE=sequential  # sequential, stepwise, etc.

# ========================================
# Memory Configuration
# ========================================
MEMORY_TYPE=in_memory  # in_memory, redis, mongodb
MEMORY_MAX_TOKENS=4000
MEMORY_RETENTION_HOURS=24

# ========================================
# Database Configuration (Optional)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/agentic_system
MONGODB_URL=mongodb://localhost:27017/agentic_system

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/agent.log

# ========================================
# Agent Configuration
# ========================================
AGENT_NAME=DefaultAgent
AGENT_DESCRIPTION=Agentic System Conversational Agent
AGENT_SYSTEM_PROMPT=You are a helpful AI assistant.
AGENT_TIMEOUT=300

# ========================================
# API Server Configuration
# ========================================
API_PORT=8000
API_HOST=0.0.0.0
API_DEBUG=false

# ========================================
# External Services
# ========================================
# Búsqueda Web
SEARCH_ENGINE_API_KEY=
SEARCH_ENGINE_URL=

# Base de Datos Vectorial (Embeddings)
VECTOR_DB_TYPE=chroma  # chroma, weaviate, pinecone
VECTOR_DB_URL=http://localhost:8000

# ========================================
# Development Mode
# ========================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true
